+import { useRef } from 'react';
+import { View, Text, Pressable, StyleSheet } from 'react-native';
+import type { BottomTabBarProps } from '@react-navigation/bottom-tabs';
+import { useSafeAreaInsets } from 'react-native-safe-area-context';
+import BottomSheet from '@gorhom/bottom-sheet';
+import { Ionicons } from '@expo/vector-icons';
+import { HomeIcon } from './HomeIcon';
+import { BrowseSheet } from './BrowseSheet';
+import { colors, spacing, typography } from '@/theme';
+
+type IoniconsName = React.ComponentProps<typeof Ionicons>['name'];
+
+// Real tab screens (3 of 4 slots — Browse is a sheet, not a route)
+const TABS: { name: string; label: string; icon: 'home' | IoniconsName }[] = [
+  { name: 'index',     label: 'Home',   icon: 'home' },
+  { name: 'bookmarks', label: 'Saved',  icon: 'heart-outline' },
+  { name: 'agents',    label: 'Agents', icon: 'people-outline' },
+];
+
+export function CustomTabBar({ state, navigation }: BottomTabBarProps) {
+  const insets = useSafeAreaInsets();
+  const sheetRef = useRef<BottomSheet>(null);
+
+  const openBrowse = () => sheetRef.current?.expand();
+
+  return (
+    <>
+      <View style={[s.bar, { paddingBottom: Math.max(insets.bottom, spacing[3]) }]}>
+        {/* Home */}
+        <TabButton
+          active={isActive(state, 'index')}
+          label="Home"
+          onPress={() => navigation.navigate('index' as never)}
+          iconComponent={
+            <HomeIcon
+              size={20}
+              color={isActive(state, 'index') ? colors.primary : colors.inactive}
+            />
+          }
+        />
+
+        {/* Browse (sheet trigger) */}
+        <TabButton
+          active={false}
+          label="Browse"
+          onPress={openBrowse}
+          iconComponent={
+            <Ionicons name="grid-outline" size={20} color={colors.inactive} />
+          }
+        />
+
+        {/* Saved */}
+        <TabButton
+          active={isActive(state, 'bookmarks')}
+          label="Saved"
+          onPress={() => navigation.navigate('bookmarks' as never)}
+          iconComponent={
+            <Ionicons
+              name={isActive(state, 'bookmarks') ? 'heart' : 'heart-outline'}
+              size={20}
+              color={isActive(state, 'bookmarks') ? colors.primary : colors.inactive}
+            />
+          }
+        />
+
+        {/* Agents */}
+        <TabButton
+          active={isActive(state, 'agents')}
+          label="Agents"
+          onPress={() => navigation.navigate('agents' as never)}
+          iconComponent={
+            <Ionicons
+              name={isActive(state, 'agents') ? 'people' : 'people-outline'}
+              size={20}
+              color={isActive(state, 'agents') ? colors.primary : colors.inactive}
+            />
+          }
+        />
+      </View>
+
+      <BrowseSheet ref={sheetRef} />
+    </>
+  );
+}
+
+function isActive(state: BottomTabBarProps['state'], name: string) {
+  return state.routes[state.index]?.name === name;
+}
+
+function TabButton({
+  active, label, onPress, iconComponent,
+}: {
+  active: boolean;
+  label: string;
+  onPress: () => void;
+  iconComponent: React.ReactNode;
+}) {
+  return (
+    <Pressable
+      style={s.tab}
+      onPress={onPress}
+      accessibilityRole="button"
+      accessibilityState={active ? { selected: true } : {}}
+      accessibilityLabel={label}
+    >
+      <View style={s.iconWrap}>{iconComponent}</View>
+      <Text style={[s.label, active && s.labelActive]}>{label}</Text>
+    </Pressable>
+  );
+}
+
+const s = StyleSheet.create({
+  bar: {
+    flexDirection: 'row',
+    backgroundColor: colors.surface,
+    borderTopWidth: 1,
+    borderTopColor: colors.border,
+    paddingHorizontal: spacing[2],
+    paddingTop: spacing[2],
+    alignItems: 'center',
+  },
+  tab: {
+    flex: 1,
+    alignItems: 'center',
+    justifyContent: 'center',
+    gap: 4,
+    paddingVertical: spacing[1],
+  },
+  iconWrap: { height: 22, alignItems: 'center', justifyContent: 'center' },
+  label: {
+    fontFamily: typography.fontFamily.body,
+    fontSize: typography.size.xs,
+    fontWeight: typography.weight.semibold,
+    letterSpacing: typography.letterSpacing.wide,
+    color: colors.inactive,
+  },
+  labelActive: { color: colors.primary },
+});
+```
