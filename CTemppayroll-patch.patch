+import { View, Text, Pressable, StyleSheet } from 'react-native';
+import { Image } from 'expo-image';
+import { Ionicons } from '@expo/vector-icons';
+import { useRouter } from 'expo-router';
+import { colors, spacing, radius, typography, shadows } from '@/theme';
+import { formatPrice, formatSqft } from '@/lib/format';
+import type { MockProperty } from '@/hooks/useMockProperties';
+
+const BLURHASH = 'L6PZfSi_.AyE_3t7t7R**0o#DgR4';
+
+interface Props {
+  property: MockProperty;
+  isBookmarked?: boolean;
+  onBookmarkToggle?: () => void;
+}
+
+export function PropertyCard({ property, isBookmarked, onBookmarkToggle }: Props) {
+  const router = useRouter();
+
+  return (
+    <Pressable
+      onPress={() => router.push(`/property/${property.id}` as any)}
+      style={({ pressed }) => [s.card, pressed && s.pressed]}
+    >
+      <View style={s.imageWrap}>
+        <Image
+          source={{ uri: property.image }}
+          style={s.image}
+          placeholder={BLURHASH}
+          transition={200}
+          contentFit="cover"
+        />
+        {property.isFeatured && (
+          <View style={s.featuredBadge}>
+            <Text style={s.featuredText}>★ Featured</Text>
+          </View>
+        )}
+        <Pressable
+          onPress={(e) => { e.stopPropagation(); onBookmarkToggle?.(); }}
+          hitSlop={8}
+          style={s.bookmarkBtn}
+        >
+          <Ionicons
+            name={isBookmarked ? 'heart' : 'heart-outline'}
+            size={22}
+            color={isBookmarked ? colors.danger : colors.textInverse}
+          />
+        </Pressable>
+      </View>
+
+      <View style={s.body}>
+        <Text style={s.title} numberOfLines={1}>{property.title}</Text>
+        <Text style={s.location} numberOfLines={1}>{property.location}</Text>
+        <View style={s.meta}>
+          <Text style={s.price}>{formatPrice(property.price)}</Text>
+          <Text style={s.dot}> · </Text>
+          <Text style={s.stats}>{formatSqft(property.sqft)}</Text>
+          {property.bedrooms > 0 && (
+            <>
+              <Text style={s.dot}> · </Text>
+              <Text style={s.stats}>{property.bedrooms} BHK</Text>
+            </>
+          )}
+        </View>
+      </View>
+    </Pressable>
+  );
+}
+
+const s = StyleSheet.create({
