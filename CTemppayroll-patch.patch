+        <div className={styles.formGroup} style={{ margin: 0 }}>
+            <label className={styles.formLabel} style={{ marginBottom: 3 }}>{label}</label>
+            <input
+                type="number"
+                min="0"
+                className={styles.formInput}
+                style={{ padding: '0.4rem 0.625rem' }}
